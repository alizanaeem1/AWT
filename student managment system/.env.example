# Copy this file to ".env" in the same folder and paste your key.
# Restart the app (stop and run `npm run dev` again) after saving.

# Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: preferred model tried first — app still falls through the rest on quota/errors
# GEMINI_MODEL=gemini-1.5-flash

# Or use Anthropic instead (https://console.anthropic.com/) — only one provider is required:
# ANTHROPIC_API_KEY=
